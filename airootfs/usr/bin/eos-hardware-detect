#!/usr/bin/env bash
# SPDX-License-Identifier: GPL-3.0-or-later
# eos-hardware-detect — unified hardware detection wrapper for EndeavourOS live ISO.
#
# Detects:
#   - Broadcom WiFi (calls broadcom-wl_detect.sh)
#   - Legacy Intel GPU (calls intel-legacy-gpu-installer)
#   - NVIDIA GPU (suggests nouveau / nvidia-inst)
#   - Virtualisation environment (VirtualBox, VMware, KVM/QEMU)
#
# Outputs a clean hardware summary and logs results to /tmp/eos-hardware-detect.log.
set -euo pipefail

LOG_FILE="/tmp/eos-hardware-detect.log"
: > "$LOG_FILE"

# ---------------------------------------------------------------------------
# Helpers
# ---------------------------------------------------------------------------

# Color support
if command -v tput &>/dev/null && [[ "$(tput colors 2>/dev/null || echo 0)" -ge 8 ]]; then
    C_GREEN=$(tput setaf 2)
    C_YELLOW=$(tput setaf 3)
    C_RED=$(tput setaf 1)
    C_CYAN=$(tput setaf 6)
    C_BOLD=$(tput bold)
    C_RESET=$(tput sgr0)
else
    C_GREEN=$'\033[0;32m'
    C_YELLOW=$'\033[1;33m'
    C_RED=$'\033[0;31m'
    C_CYAN=$'\033[0;36m'
    C_BOLD=$'\033[1m'
    C_RESET=$'\033[0m'
fi

log()         { printf '%s\n'                    "$*" | tee -a "$LOG_FILE"; }
log_info()    { printf '%b[INFO]%b  %s\n'  "$C_GREEN"  "$C_RESET" "$*" | tee -a "$LOG_FILE"; }
log_warn()    { printf '%b[WARN]%b  %s\n'  "$C_YELLOW" "$C_RESET" "$*" | tee -a "$LOG_FILE"; }
log_error()   { printf '%b[ERROR]%b %s\n'  "$C_RED"    "$C_RESET" "$*" | tee -a "$LOG_FILE" >&2; }
log_section() { printf '\n%b==> %s%b\n'    "$C_CYAN"   "$*" "$C_RESET" | tee -a "$LOG_FILE"; }

# ---------------------------------------------------------------------------
# Prerequisite check
# ---------------------------------------------------------------------------
for _tool in lspci grep; do
    if ! command -v "$_tool" &>/dev/null; then
        log_error "$_tool not found. Please install pciutils / grep."
        exit 2
    fi
done

# ---------------------------------------------------------------------------
# Banner
# ---------------------------------------------------------------------------
log ""
log "${C_BOLD}EndeavourOS Hardware Detection${C_RESET}"
log "$(date '+%Y-%m-%d %H:%M:%S')"
log "Log: $LOG_FILE"
log ""

# ---------------------------------------------------------------------------
# 1. Virtualisation detection
# ---------------------------------------------------------------------------
log_section "Virtualisation Detection"

detect_vm() {
    local vm_type="none"

    # systemd-detect-virt is the most reliable single source
    if command -v systemd-detect-virt &>/dev/null; then
        local virt
        virt=$(systemd-detect-virt 2>/dev/null || true)
        case "$virt" in
            none)   vm_type="none" ;;
            kvm)    vm_type="kvm" ;;
            qemu)   vm_type="qemu" ;;
            vmware) vm_type="vmware" ;;
            oracle) vm_type="virtualbox" ;;
            *)      vm_type="$virt" ;;
        esac
    fi

    # Fallback: PCI device strings
    if [[ "$vm_type" == "none" ]]; then
        local pci_data
        pci_data=$(lspci 2>/dev/null || true)
        if echo "$pci_data" | grep -qi 'VirtualBox'; then
            vm_type="virtualbox"
        elif echo "$pci_data" | grep -qi 'VMware'; then
            vm_type="vmware"
        elif echo "$pci_data" | grep -qi 'QEMU\|Red Hat.*Virtio'; then
            vm_type="kvm"
        fi
    fi

    printf '%s' "$vm_type"
}

VM_TYPE=$(detect_vm)

case "$VM_TYPE" in
    none)
        log_info "Running on bare-metal hardware."
        ;;
    virtualbox)
        log_warn "VirtualBox guest detected."
        log_warn "Tip: Install 'virtualbox-guest-utils' for better display/clipboard integration."
        ;;
    vmware)
        log_warn "VMware guest detected."
        log_warn "Tip: Install 'open-vm-tools' for better display/clipboard integration."
        ;;
    kvm|qemu)
        log_warn "KVM/QEMU guest detected."
        log_warn "Tip: The 'virtio' drivers and 'spice-vdagent' provide best performance."
        ;;
    *)
        log_warn "Virtualisation detected: $VM_TYPE"
        ;;
esac

# ---------------------------------------------------------------------------
# 2. NVIDIA GPU detection
# ---------------------------------------------------------------------------
log_section "NVIDIA GPU Detection"

nvidia_devices=$(lspci -nn | grep -iP 'VGA|Display|3D' | grep -i 'NVIDIA' || true)

if [[ -n "$nvidia_devices" ]]; then
    log_warn "NVIDIA GPU detected:"
    while IFS= read -r _line; do
        log_warn "  $_line"
    done <<< "$nvidia_devices"
    log_warn "Options:"
    log_warn "  - Open-source: 'nouveau' is loaded by default."
    log_warn "  - Proprietary: run 'nvidia-inst' after installation for the nvidia driver."
    log_warn "  - For Turing/Ampere (RTX 20xx/30xx/40xx) use: nvidia-inst --series 560"
else
    log_info "No NVIDIA GPU detected."
fi

# ---------------------------------------------------------------------------
# 3. Legacy Intel GPU detection
# ---------------------------------------------------------------------------
log_section "Intel Legacy GPU Detection"

if [[ -x /usr/bin/intel-legacy-gpu-installer ]]; then
    if /usr/bin/intel-legacy-gpu-installer --dry-run >> "$LOG_FILE" 2>&1; then
        log_warn "Legacy Intel GPU (Gen 1-4) detected — xf86-video-intel will be installed by intel.service."
    else
        log_info "No legacy Intel GPU (Gen 1-4) detected."
    fi
else
    log_warn "intel-legacy-gpu-installer not found; skipping Intel GPU check."
fi

# ---------------------------------------------------------------------------
# 4. Broadcom WiFi detection
# ---------------------------------------------------------------------------
log_section "Broadcom WiFi Detection"

if [[ -x /usr/bin/broadcom-wl_detect.sh ]]; then
    if /usr/bin/broadcom-wl_detect.sh >> "$LOG_FILE" 2>&1; then
        log_warn "Broadcom WiFi device found — broadcom-wl_detect.sh handled it."
    else
        _exit=$?
        if [[ $_exit -eq 1 ]]; then
            log_info "No Broadcom WiFi device requiring broadcom-wl was found."
        else
            log_error "broadcom-wl_detect.sh returned an error (exit $_exit)."
        fi
    fi
else
    log_warn "broadcom-wl_detect.sh not found; skipping Broadcom WiFi check."
fi

# ---------------------------------------------------------------------------
# 5. Summary
# ---------------------------------------------------------------------------
log_section "Hardware Summary"

all_pci=$(lspci -nn 2>/dev/null || true)

# GPU summary
gpu_lines=$(echo "$all_pci" | grep -iP 'VGA|Display|3D' || true)
if [[ -n "$gpu_lines" ]]; then
    log_info "Graphics device(s) found:"
    while IFS= read -r _line; do
        log      "    $_line"
    done <<< "$gpu_lines"
else
    log_warn "No graphics device found via lspci."
fi

# Network summary
net_lines=$(echo "$all_pci" | grep -iP 'network|wireless|ethernet' || true)
if [[ -n "$net_lines" ]]; then
    log_info "Network device(s) found:"
    while IFS= read -r _line; do
        log      "    $_line"
    done <<< "$net_lines"
else
    log_warn "No network device found via lspci."
fi

log ""
log_info "Detection complete. Full log written to: $LOG_FILE"
log ""
